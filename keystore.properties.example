# Modèle — copie ce fichier en `keystore.properties` (à la racine du projet) et remplis-le.
# `keystore.properties` est gitignoré : il ne doit JAMAIS être commité.
#
# storeFile : chemin de la clé, RELATIF à la racine du projet (ou absolu).
#   Recommandé : place le .jks HORS du repo (ex. ~/keys/trivia-upload.jks) et mets le chemin absolu.
storeFile=../keys/trivia-upload.jks
storePassword=TON_MOT_DE_PASSE_KEYSTORE
keyAlias=upload
keyPassword=TON_MOT_DE_PASSE_CLE
