    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="13" android:startY="0"
                android:endX="95" android:endY="108">
                <item android:offset="0.0" android:color="#FF8B6CFF" />
                <item android:offset="0.46" android:color="#FF7A5AF8" />
                <item android:offset="1.0" android:color="#FF553BD0" />
